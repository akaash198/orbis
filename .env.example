# ============================================
# Orbisporte Environment Configuration
# ============================================
# Copy this file to .env and configure your values

# ── Application ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Ports ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_DB=orbisporte
POSTGRES_USER=orbisporte
POSTGRES_PASSWORD=orbisporte_secure_password_change_this

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secure_password_change_this

# ── Security ────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────
# Use * for development, or comma-separated list of origins for production
# Example: CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*

# ── AI/LLM Configuration ─────────────────────────────────────────────
# OpenAI API Key (required for LLM features)
OPENAI_API_KEY=sk-your-openai-api-key

# OpenRouter (alternative - used if OPENAI_API_KEY is not set)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=gpt-4o-mini

# Voyage AI (for embeddings)
VOYAGE_API_KEY=your-voyage-api-key

# ── File Storage ────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800

# ── Kafka (Optional - for async processing) ──────────────────────────
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Data Lake (Optional - S3 compatible) ───────────────────────────
DATA_LAKE_TYPE=local
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=orbisporte-data-lake

# ── Frontend API URLs ────────────────────────────────────────────────
# These are used during Docker build for the frontend
API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000
