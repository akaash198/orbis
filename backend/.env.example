# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=orbisporte_db

# Database URL
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/orbisporte_db

# JWT Secret Key
JWT_SECRET_KEY=change-this-to-a-secure-random-key-in-production

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ===== AI/ML Configuration =====

# OpenAI Configuration (REQUIRED for document extraction)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=api key
# Alternative LLM Options (Optional)
# GROK_API_KEY=your_grok_api_key_here
# GROK_BASE_URL=https://api.x.ai/v1

# Azure OpenAI (Optional - if using Azure instead of OpenAI)
# AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here

# LLM Provider Selection (openai, azure, grok, openrouter)
LLM_PROVIDER=openai

# ChromaDB for vector embeddings
CHROMA_DB_PATH=./static/chroma_db
CHROMA_COLLECTION_NAME=orbisporte_documents

# Application Settings
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=pdf,jpg,jpeg,png

# ── Data Intake and Management ──────────────────────────────────────────────

# Apache Kafka (message queue)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=orbis.intake

# RustFS / MinIO object storage (S3-compatible)
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=minioadmin
RUSTFS_SECRET_KEY=minioadmin
DATALAKE_RAW_BUCKET=orbis-raw
DATALAKE_PROCESSED_BUCKET=orbis-processed
DATALAKE_CURATED_BUCKET=orbis-curated
# Set to "true" to skip RustFS and use local filesystem (development)
DATALAKE_USE_LOCAL=true
DATALAKE_LOCAL_ROOT=./data_lake

# Semantic deduplication (FAISS + all-MiniLM-L6-v2)
DEDUP_THRESHOLD=0.92
FAISS_INDEX_PATH=./data/faiss_dedup.index
FAISS_META_PATH=./data/faiss_dedup_meta.pkl

# SFTP ingestion channel
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=
SFTP_DROP_FOLDER=/incoming
SFTP_DONE_FOLDER=/processed

# Email (IMAP) ingestion channel
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX
EMAIL_ALLOWED_DOMAINS=

# Whisper ASR (uses existing OPENAI_API_KEY)
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=

# ── M03 HSN Classification Engine ───────────────────────────────────────────
# Uses the existing OPENAI_API_KEY for both GPT-4o-mini (classification)
# and text-embedding-3-small (HSN semantic search). No extra keys needed.
